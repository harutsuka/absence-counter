<link rel="stylesheet" href="/css/index.css">
<link rel="stylesheet" href="/css/edit_form.css">

<script src="https://cdn.jsdelivr.net/npm/progressbar.js"></script>

<h2>アーカイブした科目</h2>
<div class="subject-list">
    <% @archived_subjects.each do |subject| %>
    <% max_absences = (subject.class_count * (1- @user.absent_ratio)).round - 1 %>

    <div class="subject-item" data-day="<%= subject.day %>">
        <h3><%= subject.name %></h3>
        <div class="days">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="20" height="20">
                <path d="M5.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H6a.75.75 0 0 1-.75-.75V12ZM6 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H6ZM7.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H8a.75.75 0 0 1-.75-.75V12ZM8 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H8ZM9.25 10a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H10a.75.75 0 0 1-.75-.75V10ZM10 11.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V12a.75.75 0 0 0-.75-.75H10ZM9.25 14a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H10a.75.75 0 0 1-.75-.75V14ZM12 9.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V10a.75.75 0 0 0-.75-.75H12ZM11.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H12a.75.75 0 0 1-.75-.75V12ZM12 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H12ZM13.25 10a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H14a.75.75 0 0 1-.75-.75V10ZM14 11.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V12a.75.75 0 0 0-.75-.75H14Z" />
                <path fill-rule="evenodd" d="M5.75 2a.75.75 0 0 1 .75.75V4h7V2.75a.75.75 0 0 1 1.5 0V4h.25A2.75 2.75 0 0 1 18 6.75v8.5A2.75 2.75 0 0 1 15.25 18H4.75A2.75 2.75 0 0 1 2 15.25v-8.5A2.75 2.75 0 0 1 4.75 4H5V2.75A.75.75 0 0 1 5.75 2Zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75Z" clip-rule="evenodd" />
            </svg>

            <md-chip-set>
                <% subject.day.split(',').each do |day| %>
                    <md-suggestion-chip label="<%= DAY_JP[day] %>"></md-suggestion-chip>
                <% end %>
            </md-chip-set>
        </div>

        <div class="menu-wrapper">
            <button class="menu-button">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
                </svg>
            </button>

            <div class="click-menu">
                <div class="button-container">
                    <button
                        onclick="location.href='/unarchive/<%= subject.id %>'"
                        class="unarchive-button"
                        data-id="<%= subject.id %>" 
                        data-name="<%= subject.name %>"
                        data-class="<%= subject.class_count %>"
                        data-absent="<%= subject.absent_count %>"
                        data-day="<%= subject.day %>">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                        </svg>
                        <span>復元</span>
                    </button>
                </div>

                <div class="button-container">
                    <button
                        onclick="location.href='/delete/<%= subject.id %>'"
                        class="delete-button"
                        data-id="<%= subject.id %>" 
                        data-name="<%= subject.name %>"
                        data-class="<%= subject.class_count %>"
                        data-absent="<%= subject.absent_count %>"
                        data-day="<%= subject.day %>">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        <span>削除</span>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="attendance">
            <p>欠席: </p>
            <h3><%= subject.absent_count %></h3><p>/ <%= max_absences %>回</p>
        </div>

        <% @progress = subject.absent_count.to_f / max_absences %>
        <div class="progress-bar" data-progress="<%= @progress %>"></div>
        <div class="remaining-absence">
        <p>残り: <h3><%= max_absences - subject.absent_count %></h3>回</p>
        </div>
        
        <form method="post" action="/record_absence/<%= subject.id %>">
            <button type="button" class="record-absence-button limit-reached-button" disabled>欠席を記録</button>
        </form>
    </div>
    <% end %>

</div>

<script>
    const filterButtons = document.querySelectorAll('.filter-day-button')
    filterButtons.forEach(button =>{
        button.addEventListener('click',()=>{
            const day = button.dataset.day
            document.querySelectorAll('.subject-item').forEach(item =>{
                if(!day || item.dataset.day.includes(day)){
                    item.style.display = 'block'
                }else{
                    item.style.display = 'none'
                }
            })
        filterButtons.forEach(btn => btn.classList.remove('selected'))
        button.classList.add('selected')
        })
    })

    document.querySelectorAll('.progress-bar').forEach(container =>{
        const progress = parseFloat(container.dataset.progress)
        var bar = new ProgressBar.Line(container, {
        strokeWidth: 4,
        color: '#FFEA82',
        trailColor: '#eee',
        trailWidth: 1,
        svgStyle: {width: '100%', height: '100%'},
        from: {color: '#FFEA82'},
        to: {color: '#f5595e'},
        step: (state, bar) => {
            bar.path.setAttribute('stroke', state.color);
        }
    });
        bar.animate(progress);
    })
    
   document.querySelectorAll('.menu-wrapper').forEach(wrapper => {
    const button = wrapper.querySelector('.menu-button');

    button.addEventListener('click', (e) => {
        e.stopPropagation();

        document.querySelectorAll('.menu-wrapper').forEach(w => {
        if (w !== wrapper) w.classList.remove('open');
        });

        wrapper.classList.toggle('open');
    });
    });

    document.addEventListener('click', () => {
    document.querySelectorAll('.menu-wrapper').forEach(w => {
        w.classList.remove('open');
    });
});
</script>
